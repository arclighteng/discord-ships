# Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# EasyPost API Key
# Get this from https://www.easypost.com/account/api-keys
# Use EZTEST... prefix for test mode, EZAK... for production
EASYPOST_API_KEY=your_easypost_api_key_here

# Shippo API Key
# Get this from https://goshippo.com/user/apikeys
# Use shippo_test_... prefix for test mode, shippo_live_... for production
SHIPPO_API_KEY=your_shippo_api_key_here

# Your return address (FROM address for shipping labels)
FROM_NAME=Your Business Name
FROM_STREET=123 Main St
FROM_CITY=City
FROM_STATE=TX
FROM_ZIP=12345
FROM_PHONE=555-555-5555
